# FRIDAY Environment Variables Example
# Copy to ~/.friday/.env

# General
FRIDAY_LOG_LEVEL=INFO
FRIDAY_PERSONA_NAME=Friday

# LLM Configuration
FRIDAY_LLM_PRIMARY_MODEL=qwen2.5-coder:7b
FRIDAY_LLM_FALLBACK_MODEL=phi4
FRIDAY_LLM_OLLAMA_BASE_URL=http://localhost:11434

# Cloud Mode (Optional)
FRIDAY_LLM_CLOUD_MODE=0
FRIDAY_LLM_OPENAI_API_KEY=your_openai_key
FRIDAY_LLM_ANTHROPIC_API_KEY=your_anthropic_key

# Memory Configuration
FRIDAY_MEMORY_CHUNK_SIZE=1000
FRIDAY_MEMORY_CHUNK_OVERLAP=200
